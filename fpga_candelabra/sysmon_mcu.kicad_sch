	(text_box "MGMT I2C Bus:\n - (1.8V) 0b011 0010 FPGA SYSMON I2C DRP\n - (2.5V) 0b001 1001 DDR4 SPD Temp\n - (2.5V) 0b011 0001 DDR4 SPD Utility\n - (2.5V) 0b101 0001 DDR4 SPD R/W\n - (3.3V) 0b101 0000 FMC0 I2C EEPROM\n - (3.3V) 0bxxx xx00 FMC0 I2C Optional\n - (3.3V) 0b101 0101 CDCM6208 PLL\n - (3.3V) 0b110 0111 TPS53667 PMBus\n - (3.3V) 0b110 0001 FMC_VADJ DAC\n"
